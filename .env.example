# ============================================
# FJR Services - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Database (PostgreSQL)
POSTGRES_USER=fjruser
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=fjrservices

# MinIO (Object Storage)
MINIO_ROOT_USER=fjrminio
MINIO_ROOT_PASSWORD=change-this-minio-password

# JWT Secrets (generate strong random strings, min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# API URL (for frontend)
VITE_API_URL=/api

# Telegram Bot (optional - leave empty to disable)
TELEGRAM_BOT_TOKEN=
